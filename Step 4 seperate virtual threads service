3. The New Service (The Orchestrator)
This is your new service. It uses Guava to partition the data, creates the virtual threads, calls your existing service,
and aggregates the results.
import com.google.common.collect.Lists;
import org.springframework.stereotype.Service;

import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.Callable;
import java.util.concurrent.Executors;
import java.util.concurrent.Future;

@Service
public class VirtualThreadOrchestratorService {

    private final SalesforceIntegrationService salesforceService;

    // Standard constructor injection
    public VirtualThreadOrchestratorService(SalesforceIntegrationService salesforceService) {
        this.salesforceService = salesforceService;
    }

    public List<SyncResult> processInParallel(List<SalesforceRecord> allRecords) {
        // Salesforce Composite API typically accepts up to 200 records per request
        int batchSize = 200; 
        List<List<SalesforceRecord>> batches = Lists.partition(allRecords, batchSize);

        // Map each batch to a task that calls your EXISTING service
        List<Callable<List<SyncResult>>> tasks = batches.stream()
                .map(batch -> (Callable<List<SyncResult>>) () -> salesforceService.pushBatchToSalesforce(batch))
                .toList();

        List<SyncResult> finalResults = new ArrayList<>();

        // Spin up the virtual threads and execute
        try (var executor = Executors.newVirtualThreadPerTaskExecutor()) {
            
            // This blocks the orchestrator thread until all Salesforce API calls return
            List<Future<List<SyncResult>>> futures = executor.invokeAll(tasks);

            // Collect the results from the Futures
            for (Future<List<SyncResult>> future : futures) {
                finalResults.addAll(future.get());
            }

        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            throw new RuntimeException("Parallel processing was interrupted", e);
        } catch (Exception e) {
            throw new RuntimeException("Error fetching results from virtual threads", e);
        }

        return finalResults;
    }
}

Why this architecture shines:
 * Separation of Concerns: SalesforceIntegrationService is strictly focused on HTTP headers, payloads, and API contracts. VirtualThreadOrchestratorService is strictly focused on concurrency and aggregation.
 * Easy Profiling: When looking at logs or traces, you will clearly see the orchestrator thread waiting, while the worker-X virtual threads are busy executing the SalesforceIntegrationService methods.
 * Safe I/O Yielding: Because the actual HTTP call happens inside pushBatchToSalesforce, the moment that method waits for the Salesforce server to respond, the JVM automatically unmounts that specific virtual thread, freeing up system resources.
