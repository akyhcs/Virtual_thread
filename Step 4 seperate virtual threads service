        System.out.println(Thread.currentThread() + " executing Salesforce API call for batch size: " + batch.size());
        
        // 1. Convert your records to the Salesforce API format
        // 2. Execute the REST template / HTTP Client call to Salesforce Bulk/Composite API
        // 3. Parse the response
        
        // Mocking the I/O delay and response
        try {
            Thread.sleep(1000); // The virtual thread will yield the carrier thread here
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        return batch.stream()
                .map(record -> new SyncResult(record.externalId(), true, "001xx00000" + record.externalId(), null))
